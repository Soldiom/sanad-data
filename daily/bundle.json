t":6,"partial":8,"acc":42},"updated":"2026-07-20T15:46+00:00"},"analyst":{"name":"المُستقرِئ","title":"محلل استراتيجي · مساعد ذكاء اصطناعي","text":"شكرًا لك. المشهد اليوم يُقرأ من ثلاث زوايا: الأولى تكمن في جدية التهديدات الأميركية، والثانية في مرونة القنوات الدبلوماسية الإيرانية، والثالثة في حراك الوسطاء الحثيث. وبناءً على هذه المعطيات، نجد أن السيناريو الأكثر ترجيحاً بنسبة 45% هو الذهاب نحو تصعيد أوسع يشمل ضربات أميركية لبنى تحتية إيرانية وردوداً تطال مواقع حيوية، مدفوعاً بنبرة ترامب الحازمة، وهو ما يعيد إلى الأذهان سوابق الضربات المتبادلة في عام 2026. في المقابل، تظل فرضية التبادل المحدود بنسبة 35%، واحتواء الموقف عبر الوسطاء بنسبة 20% خيارات قائمة لخفض التصعيد. وتبقى هذه قراءةً احتمالية، والمؤشر الحاسم هو مدى قدرة الوسطاء على صياغة اتفاق هدنة مؤقتة خلال الساعات المقبلة.","audio":"analyst.mp3","src":"2026-07-20T15:46+00:00","avatar":"analyst.jpg","updated":"2026-07-20T15:46+00:00"},"dua":{"title":"دعاءٌ للكويتِ والخليجِ وجميعِ المسلمين","items":[{"t":"حَسْبُنَا اللَّهُ وَنِعْمَ الْوَكِيلُ","s":"سورة آل عمران — الآية ١٧٣","k":"قرآن"},{"t":"اللَّهُمَّ إِنَّا نَجْعَلُكَ فِي نُحُورِهِمْ، وَنَعُوذُ بِكَ مِنْ شُرُورِهِمْ","s":"كان النبي ﷺ إذا خافَ قومًا قالَ هذا — رواه أبو داود والنسائي","k":"مأثور"},{"t":"لَا إِلَهَ إِلَّا اللَّهُ الْعَظِيمُ الْحَلِيمُ، لَا إِلَهَ إِلَّا اللَّهُ رَبُّ الْعَرْشِ الْعَظِيمِ، لَا إِلَهَ إِلَّا اللَّهُ رَبُّ السَّمَاوَاتِ وَرَبُّ الْأَرْضِ وَرَبُّ الْعَرْشِ الْكَرِيمِ","s":"دعاءُ الكرب — متفقٌ عليه، البخاري ومسلم","k":"مأثور"},{"t":"اللَّهُمَّ إِنِّي أَعُوذُ بِكَ مِنْ زَوَالِ نِعْمَتِكَ، وَتَحَوُّلِ عَافِيَتِكَ، وَفُجَاءَةِ نِقْمَتِكَ، وَجَمِيعِ سَخَطِكَ","s":"رواه مسلم","k":"مأثور"},{"t":"اللَّهُمَّ احْفَظِ الكويتَ وأهلَها، واحفَظْ بلادَ الخليجِ وشعوبَها، وأدِمْ عليها الأمنَ والعافية، ولا تُغيِّرْ علينا الحالَ إلا لأحسنِه","s":"دعاءٌ للكويتِ والخليج","k":"عام"},{"t":"اللَّهُمَّ انْصُرِ المسلمينَ في كلِّ مكان، وارفَعْ عنهمُ البلاءَ والوباءَ والغلاء، واجمَعْ كلمتَهم على الحقِّ والهدى","s":"دعاءٌ لعمومِ المسلمين","k":"عام"},{"t":"اللَّهُمَّ مَنْ أرادَ بلادَنا وأهلَنا بسوءٍ فاشغَلْهُ بنفسِه، ورُدَّ كيدَه في نحرِه، واجعَلْ تدبيرَه تدميرَه يا ربَّ العالمين","s":"دعاءٌ بردِّ كيدِ مَن أرادَ السوء","k":"عام"},{"t":"اللَّهُمَّ ارحَمْ شهداءَنا، واشْفِ جَرحانا، وثبِّتْ رجالَنا، واحفَظْ نساءَنا وأطفالَنا وشيوخَنا، وأنزِلْ علينا السَّكينةَ والطُّمأنينة","s":"دعاءٌ للشهداءِ والمصابين","k":"عام"},{"t":"اللَّهُمَّ إنَّا نعوذُ بكَ مِنَ الفَواجِع، وأن تُرِيَنا في أهلِنا وبلدِنا ما يُؤلِمُ القلوب، واكتُبْ لنا الأمنَ بعدَ الخوف","s":"دعاءٌ بدفعِ الفواجع","k":"عام"}],"note":""},"verify":{"updated":"2026-07-20T07:06+00:00","src_updated":"2026-07-20T07:05+00:00","matched":1,"total":9,"rows":[{"c":"إيران","r":"مطابق","alt":"","by":"الجزيرة وويكيبيديا","note":"تقارير عن 3468-3518 قتيلا وأكثر من 26500 جريحا وفق وزارة الصحة وHRANA"},{"c":"الولايات المتحدة","r":"متباين","alt":"6 قتلى و5-18 جريحا خطير","by":"CENTCOM","note":"الأرقام الرسمية أقل بكثير من المعلن"},{"c":"الكويت","r":"متباين","alt":"7 قتلى مدنيون و105 جريحا تقريبا","by":"ويكيبيديا وتقارير","note":"أرقام متفاوتة ولا تطابق الدقيق"},{"c":"السعودية","r":"غير موثّق","alt":"","by":"","note":"لا مصدر مستقل يؤكد الأرقام"},{"c":"الإمارات","r":"غير موثّق","alt":"","by":"","note":"لا مصدر مستقل يؤكد الأرقام"},{"c":"قطر","r":"غير موثّق","alt":"","by":"","note":"لا مصدر مستقل يؤكد الأرقام"},{"c":"البحرين","r":"غير موثّق","alt":"","by":"","note":"لا مصدر مستقل يؤكد الأرقام"},{"c":"عُمان","r":"غير موثّق","alt":"","by":"","note":"لا مصدر مستقل يؤكد الأرقام"},{"c":"العراق","r":"غير موثّق","alt":"","by":"","note":"لا مصدر مستقل يؤكد الأرقام"}]},"alerts":{"updated":"2026-07-20T15:45+00:00","list":[{"kind":"تحذير","body":"رئاسة الأركان العامة للجيش","txt":"الدفاعات الجوية تتصدى حاليا لهجمات صاروخية وطائرات مسيرة معادية إثر العدوان الإيراني الآثم وأصوات الانفجارات إن سمعت نتيجة الاعتراض","act":"التقيد بتعليمات الأمن والسلامة الصادرة عن الجهات المختصة","u":"https://x.com/KuwaitArmyGHQ/status/2079197371209031798","when":"20 يوليو 2026"},{"kind":"تحذير","body":"رئاسة الأركان العامة للجيش","txt":"عدم الاقتراب من مواقع سقوط الشظايا الناتجة عن عمليات الاعتراض والامتناع عن تصويرها أو تداول صورها","act":"الالتزام بتعليمات السلامة واستقاء المعلومات من المصادر الرسمية","u":"https://x.com/KuwaitArmyGHQ/status/2075030807626846534","when":"9 يوليو 2026"},{"kind":"تحذير","body":"قوة الإطفاء العام","txt":"السيطرة على حرائق اندلعت إثر استهداف مواقع ضمن الهجمات المعادية وتعامل مع حرائق شظايا في مناطق سكنية","act":"الابتعاد عن مواقع الحرائق والشظايا وإفساح المجال للفرق","u":"https://x.com/kff_kw/status/2078505026495090986","when":"18 يوليو 2026"},{"kind":"تحذير","body":"الخطوط الجوية الكويتية والطيران المدني","txt":"إعادة جدولة أغلب الرحلات بسبب وقف حركة الإقلاع والهبوط مؤقتا في مطار الكويت","act":"متابعة مستجدات الرحلات عبر القنوات الرسمية","u":"https://www.instagram.com/reel/Da7PwGGNFz6/","when":"18 يوليو 2026"},{"kind":"تنبيه من شائعة","body":"وزارة الداخلية","txt":"الامتناع عن تصوير اعتراض الصواريخ أو بث المقاطع ونشرها وعدم الانسياق وراء الشائعات","act":"تحري الدقة واستقاء المعلومات من المصادر الرسمية المعتمدة","u":"https://x.com/Moi_kuw/status/2027756075995292100","when":"28 فبراير 2026"},{"kind":"تحذير","body":"وزارة الداخلية البحرينية","txt":"إطلاق صافرات الإنذار والهدوء والتوجه إلى أقرب مكان آمن","act":"البقاء هادئين والتوجه لمكان آمن ومتابعة القنوات الرسمية","u":"https://x.com/alghadbreaking/status/2079230800696955232","when":"20 يوليو 2026"}]},"corrections":{"log":[{"c":"إيران","f":"🇮🇷","field":"جرحى","from":"27000","to":"26500","src":"وزارة الصحة الإيرانية وHRANA","at":"2026-07-20T07:05+00:00"},{"c":"الولايات المتحدة","f":"🇺🇸","field":"جرحى","from":"587","to":"583","src":"البنتاغون وCENTCOM","at":"2026-07-20T07:05+00:00"}],"updated":"2026-07-20T07:05+00:00"},"latest":{"date":"2026-07-20","script":"السلامُ عليكم. معكم نشرةُ سَنَد.\n\nنبدأُ نشرتَنا الإخباريةَ من الملفِ الفلسطينيِّ الساخن. حيثُ تشهدُ الأوضاعُ الميدانيةُ تصعيدًا مستمرًا في قطاعِ غزة.\n\nخبرٌ حسنٌ من مصدرٍ معتبَر: نقلًا عن الجزيرة نت، ارتقى أربعةُ شهداءَ بنيرانِ قواتِ الاحتلالِ الإسرائيليِّ في قطاعِ غزة. وتزامنَ ذلكَ مع مشاركةِ وزراءَ من حكومةِ الاحتلالِ في مسيرةٍ استيطانيةٍ حاشدةٍ نُظِّمَت على الحدود.\n\nخبرٌ حسنٌ من مصدرٍ معتبَر: ونقلًا عن سكاي نيوز عربية، قُتِلَ فلسطينيانِ اثنانِ برصاصِ وقذائفِ قواتِ الاحتلالِ الإسرائيليِّ شرقيَّ قطاعِ غزة. وتأتي هذهِ التطوراتُ الميدانيةُ في ظلِّ استمرارِ التوترِ الأمنيِّ الكبيرِ في تلكَ المناطقِ الحدودية.\n\nخبرٌ حسنٌ من مصدرٍ معتبَر: ونقلًا عن سي إن إن بالعربية، يروِّجُ اليمينُ الإسرائيليُّ بشكلٍ واسعٍ لإعادةِ استيطانِ قطاعِ غزة. وتأتي هذهِ التحركاتُ الدعائيةُ المكثفةُ مع اقترابِ موعدِ الانتخاباتِ الإسرائيليةِ المقبلة.\n\nخبرٌ حسنٌ من مصدرٍ معتبَر: ونقلًا عن الجزيرة نت، كانت فلسطينُ حاضرةً بقوةٍ في نهائيِّ بطولةِ كأسِ العالمِ لكرةِ القدمِ المونديال. وقد تسببَ بنيامين نتنياهو وإيتمار بن غفير في قلبِ بوصلةِ التشجيعِ الجماهيريِّ ضدَّ منتخبِ الأرجنتين.\n\nوننتقلُ الآنَ من الملفِّ الفلسطينيِّ إلى ملفِّ أزمةِ الخليجِ العربيِّ وتطوراتِهِ المتسارعة.\n\nخبرٌ صحيحٌ مؤكَّد: نقلًا عن رويترز، أعلنَ الحوثيونَ فرضَ حظرٍ شاملٍ على الملاحةِ البحريةِ على المملكةِ العربيةِ السعودية. ويمثلُ هذا الإعلانُ تصعيدًا جديدًا يهددُ أمنَ الممراتِ المائيةِ الحيويةِ في المنطقة.\n\nخبرٌ حسنٌ من مصدرٍ معتبَر: ونقلًا عن سي إن إن بالعربية، أعلنَ الحوثيونَ فرضَ حظرِ ملاحةٍ بحريةٍ على السعودية. ويستهدفُ هذا القرارُ حركةَ السفنِ التجاريةِ والناقلاتِ في البحرِ الأحمرِ والمضائقِ القريبة.\n\nخبرٌ حسنٌ من مصدرٍ معتبَر: ونقلًا عن الجزيرة نت، أعلنَ الحوثيونَ رسميًا حظرَ الملاحةِ البحريةِ على السفنِ التابعةِ للسعودية. ويثيرُ هذا الإعلانُ مخاوفَ دوليةً واسعةً من تعطلِ إمداداتِ الطاقةِ العالمية.\n\nخبرٌ حسنٌ من مصدرٍ معتبَر: ونقلًا عن بي بي سي، صرحت إيرانُ بأنَّ الاتصالاتِ الدبلوماسيةَ مع الأطرافِ المختلفةِ لا تزالُ مستمرة. ويأتي هذا التصريحُ الإيرانيُّ بالرغمِ من تصاعدِ حدةِ العملياتِ العسكريةِ في المنطقة.\n\nونتحولُ في محورِنا الأخيرِ إلى التطوراتِ التقنيةِ والأمنيةِ المرتبطةِ بالهجماتِ السيبرانيةِ في الخليج.\n\nخبرٌ حسنٌ من مصدرٍ معتبَر: نقلًا عن العربية، تصدت دولةُ الكويتِ بنجاحٍ لهجماتٍ إلكترونيةٍ إيرانيةٍ استهدفت أنظمتَها. وتزامنَ ذلكَ مع إطلاقِ صفاراتِ الإنذارِ في مملكةِ البحرينِ نتيجةَ هذهِ التهديدات.\n\nخبرٌ حسنٌ من مصدرٍ معتبَر: ونقلًا عن سكاي نيوز عربية، أدانت دولةُ الإماراتِ العربيةِ المتحدةِ بشدةٍ الهجماتِ الإيرانية. واستهدفت هذهِ الهجماتُ الإلكترونيةُ والسيبرانيةُ كلًا من مملكةِ البحرينِ ودولةِ الكويت.\n\nتحقَّقْ قبلَ أن تنشُر، فالكلمةُ أمانة.","audio":"bulletin-2026-07-20.mp3","video":"latest.mp4","items":[{"head":"الحوثيون يعلنون فرض \"حظر ملاحة بحرية\" على السعودية","src":"CNN Arabic","grade":"حسن"},{"head":"إيران تقول إن الاتصالات الدبلوماسية مستمرة رغم تصاعد العمليات العسكرية في المنطقة","src":"BBC","grade":"حسن"},{"head":"الحوثيون يعلنون حظر الملاحة على السفن السعودية","src":"الجزيرة نت","grade":"حسن"},{"head":"الحوثيون يعلنون حظرا على الملاحة البحرية على السعودية","src":"Reuters","grade":"صحيح"},{"head":"الإمارات تُدين بشدة الهجمات الإيرانية على البحرين والكويت","src":"سكاي نيوز عربية","grade":"حسن"},{"head":"الكويت تتصدى لهجمات إيرانية.. وإطلاق صفارات الإنذار في البحرين","src":"العربية","grade":"حسن"},{"head":"مقتل فلسطينيين اثنين بنيران إسرائيلية شرقي غزة","src":"سكاي نيوز عربية","grade":"حسن"},{"head":"4 شهداء بنيران الاحتلال في غزة ووزراؤه يشاركون بمَسيرة استيطانية على الحدود","src":"الجزيرة نت","grade":"حسن"},{"head":"اليمين الإسرائيلي يروج لإعادة استيطان غزة مع اقتراب الانتخابات","src":"CNN Arabic","grade":"حسن"},{"head":"\"فلسطين حاضرة بنهائي المونديال\".. نتنياهو وبن غفير قلبا بوصلة التشجيع ضد الأرجنتين","src":"الجزيرة نت","grade":"حسن"},{"head":"نهائي ميسي ولامين جمال يشعل جدلا سياسيا حول فلسطين وإسرائيل","src":"الجزيرة نت","grade":"حسن"},{"head":"نوال صيام.. نازحة من غزة تصنع الحلويات لتوفير حاجات أسرتها","src":"الجزيرة نت","grade":"حسن"}]},"agents":{"updated":"2026-07-20T12:47+00:00","healthy":11,"total":11,"ran":6,"slot":0,"agents":[{"id":"rasid","name":"الرَّاصِد","icon":"🛰️","role":"يرصد المصادر الحيّة ويجمع الحصيلة والعاجل","status":"skip","ms":0,"note":"يعمل بعد ~5.4س","at":"2026-07-20T12:43+00:00","ran":true},{"id":"mutabiq","name":"المُطابِق","icon":"🔍","role":"يقابل أرقام الحصيلة ب