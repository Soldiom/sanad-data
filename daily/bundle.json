لدبلوماسية الخلفية على صياغة تفاهمات سريعة تلجم التصعيد الميداني.","audio":"","src":"2026-07-20T15:39+00:00","avatar":"analyst.jpg","updated":"2026-07-20T15:39+00:00"},"dua":{"title":"دعاءٌ للكويتِ والخليجِ وجميعِ المسلمين","items":[{"t":"حَسْبُنَا اللَّهُ وَنِعْمَ الْوَكِيلُ","s":"سورة آل عمران — الآية ١٧٣","k":"قرآن"},{"t":"اللَّهُمَّ إِنَّا نَجْعَلُكَ فِي نُحُورِهِمْ، وَنَعُوذُ بِكَ مِنْ شُرُورِهِمْ","s":"كان النبي ﷺ إذا خافَ قومًا قالَ هذا — رواه أبو داود والنسائي","k":"مأثور"},{"t":"لَا إِلَهَ إِلَّا اللَّهُ الْعَظِيمُ الْحَلِيمُ، لَا إِلَهَ إِلَّا اللَّهُ رَبُّ الْعَرْشِ الْعَظِيمِ، لَا إِلَهَ إِلَّا اللَّهُ رَبُّ السَّمَاوَاتِ وَرَبُّ الْأَرْضِ وَرَبُّ الْعَرْشِ الْكَرِيمِ","s":"دعاءُ الكرب — متفقٌ عليه، البخاري ومسلم","k":"مأثور"},{"t":"اللَّهُمَّ إِنِّي أَعُوذُ بِكَ مِنْ زَوَالِ نِعْمَتِكَ، وَتَحَوُّلِ عَافِيَتِكَ، وَفُجَاءَةِ نِقْمَتِكَ، وَجَمِيعِ سَخَطِكَ","s":"رواه مسلم","k":"مأثور"},{"t":"اللَّهُمَّ احْفَظِ الكويتَ وأهلَها، واحفَظْ بلادَ الخليجِ وشعوبَها، وأدِمْ عليها الأمنَ والعافية، ولا تُغيِّرْ علينا الحالَ إلا لأحسنِه","s":"دعاءٌ للكويتِ والخليج","k":"عام"},{"t":"اللَّهُمَّ انْصُرِ المسلمينَ في كلِّ مكان، وارفَعْ عنهمُ البلاءَ والوباءَ والغلاء، واجمَعْ كلمتَهم على الحقِّ والهدى","s":"دعاءٌ لعمومِ المسلمين","k":"عام"},{"t":"اللَّهُمَّ مَنْ أرادَ بلادَنا وأهلَنا بسوءٍ فاشغَلْهُ بنفسِه، ورُدَّ كيدَه في نحرِه، واجعَلْ تدبيرَه تدميرَه يا ربَّ العالمين","s":"دعاءٌ بردِّ كيدِ مَن أرادَ السوء","k":"عام"},{"t":"اللَّهُمَّ ارحَمْ شهداءَنا، واشْفِ جَرحانا، وثبِّتْ رجالَنا، واحفَظْ نساءَنا وأطفالَنا وشيوخَنا، وأنزِلْ علينا السَّكينةَ والطُّمأنينة","s":"دعاءٌ للشهداءِ والمصابين","k":"عام"},{"t":"اللَّهُمَّ إنَّا نعوذُ بكَ مِنَ الفَواجِع، وأن تُرِيَنا في أهلِنا وبلدِنا ما يُؤلِمُ القلوب، واكتُبْ لنا الأمنَ بعدَ الخوف","s":"دعاءٌ بدفعِ الفواجع","k":"عام"}],"note":""},"verify":{"updated":"2026-07-20T07:06+00:00","src_updated":"2026-07-20T07:05+00:00","matched":1,"total":9,"rows":[{"c":"إيران","r":"مطابق","alt":"","by":"الجزيرة وويكيبيديا","note":"تقارير عن 3468-3518 قتيلا وأكثر من 26500 جريحا وفق وزارة الصحة وHRANA"},{"c":"الولايات المتحدة","r":"متباين","alt":"6 قتلى و5-18 جريحا خطير","by":"CENTCOM","note":"الأرقام الرسمية أقل بكثير من المعلن"},{"c":"الكويت","r":"متباين","alt":"7 قتلى مدنيون و105 جريحا تقريبا","by":"ويكيبيديا وتقارير","note":"أرقام متفاوتة ولا تطابق الدقيق"},{"c":"السعودية","r":"غير موثّق","alt":"","by":"","note":"لا مصدر مستقل يؤكد الأرقام"},{"c":"الإمارات","r":"غير موثّق","alt":"","by":"","note":"لا مصدر مستقل يؤكد الأرقام"},{"c":"قطر","r":"غير موثّق","alt":"","by":"","note":"لا مصدر مستقل يؤكد الأرقام"},{"c":"البحرين","r":"غير موثّق","alt":"","by":"","note":"لا مصدر مستقل يؤكد الأرقام"},{"c":"عُمان","r":"غير موثّق","alt":"","by":"","note":"لا مصدر مستقل يؤكد الأرقام"},{"c":"العراق","r":"غير موثّق","alt":"","by":"","note":"لا مصدر مستقل يؤكد الأرقام"}]},"alerts":{"updated":"2026-07-20T15:38+00:00","list":[{"kind":"تحذير","body":"رئاسة الأركان العامة للجيش","txt":"تتصدى الدفاعات الجوية لهجمات صاروخية ومسيرة معادية وأصوات الانفجارات ناتجة عن الاعتراض","act":"التقيد بتعليمات الأمن والسلامة من الجهات المختصة","u":"https://x.com/KuwaitArmyGHQ/status/2079197371209031798","when":"2026-07-20 13:30 GMT"},{"kind":"تحذير","body":"رئاسة الأركان العامة للجيش","txt":"رصد واعتراض صواريخ باليستية ومسيرات استهدفت منشآت كهرباء وماء مع أضرار وحرائق","act":"الالتزام بالتعليمات الرسمية والحفاظ على السلامة","u":"https://x.com/KuwaitArmyGHQ/status/2078902708300644452","when":"2026-07-19 18:00 GMT"},{"kind":"تحذير","body":"وزارة الكهرباء والماء والطاقة المتجددة","txt":"تعرض محطة قوى كهربائية وتقطير مياه لاعتداء أدى لحريق وتأثر وحدات توليد وتفعيل خطط طوارئ","act":"التعاون مع فرق الطوارئ وفهم انقطاعات محتملة","u":"https://x.com/mew_kwt/status/2078803473793962380","when":"2026-07-19 11:25 GMT"},{"kind":"تحذير","body":"الخطوط الجوية الكويتية","txt":"إعادة جدولة أغلب الرحلات بسبب وقف الإقلاع والهبوط مؤقتا في مطار الكويت إثر هجمات","act":"متابعة تحديثات الرحلات عبر الرسائل وخدمة العملاء","u":"https://x.com/KuwaitAirways/status/2078348854806675865","when":"2026-07-18 05:19 GMT"},{"kind":"تحذير","body":"رئاسة الأركان العامة للجيش","txt":"سقوط شظايا في مناطق سكنية مع أضرار مادية دون إصابات بشرية جراء الاعتراض","act":"عدم الاقتراب من الشظايا والإبلاغ عبر 112","u":"https://x.com/KuwaitArmyGHQ/status/2078434640470118525","when":"2026-07-18 11:00 GMT"},{"kind":"تنبيه من شائعة","body":"رئاسة الأركان العامة للجيش","txt":"الدعوة للتقيد بالتعليمات واستقاء المعلومات من المصادر الرسمية المعتمدة فقط","act":"الاعتماد على الحسابات الرسمية وعدم تداول غير الموثق","u":"https://x.com/KuwaitArmyGHQ/status/2079062763079356658","when":"2026-07-20 04:36 GMT"}]},"corrections":{"log":[{"c":"إيران","f":"🇮🇷","field":"جرحى","from":"27000","to":"26500","src":"وزارة الصحة الإيرانية وHRANA","at":"2026-07-20T07:05+00:00"},{"c":"الولايات المتحدة","f":"🇺🇸","field":"جرحى","from":"587","to":"583","src":"البنتاغون وCENTCOM","at":"2026-07-20T07:05+00:00"}],"updated":"2026-07-20T07:05+00:00"},"latest":{"date":"2026-07-19","script":"السلامُ عليكم. معكم نشرةُ سَنَد.\n\nنبدأُ جولتنا الإخباريةَ من الأراضي الفلسطينيةِ المحتلة. حيثُ يواجهُ قطاعُ غزةَ تصعيدًا ميدانيًا خطيرًا ومستمرًا.\n\nخبرٌ حسنٌ من مصدرٍ معتبَر: نقلًا عن سكاي نيوز عربية، قُتلَ فلسطينيانِ اثنانِ بنيرانٍ إسرائيليةٍ شرقيَّ غزة. وتأتي هذهِ التطوراتُ في ظلِّ توترٍ أمنيٍّ متصاعدٍ بالمنطقة.\n\nخبرٌ حسنٌ من مصدرٍ معتبَر: ونقلًا عن صحيفة الخليج، قتلَ الجيشُ الإسرائيليُّ أحدَ عشرَ فلسطينيًا. وكانَ من بينِ الضحايا أطفالٌ سقطوا في غزة.\n\nخبرٌ حسنٌ من مصدرٍ معتبَر: ونقلًا عن سكاي نيوز عربية، قُتلَ أربعةَ عشرَ فلسطينيًا في غزة. وجاءَ ذلكَ نتيجةَ هجماتٍ مكثفةٍ شنَّها الجيشُ الإسرائيلي.\n\nخبرٌ حسنٌ من مصدرٍ معتبَر: ونقلًا عن بي بي سي، سقطَ خمسةَ عشرَ قتيلًا في غزةَ منذُ السبت. وكانَ من بينِ الضحايا ثلاثةُ أطفالٍ وامرأة. وتتصاعدُ المخاوفُ حاليًا من توسيعِ نطاقِ ما يُعرفُ بالخطِّ الأصفر.\n\nوننتقلُ الآنَ إلى ملفِّ التوتراتِ الإقليميةِ والأزمةِ العسكريةِ في المنطقة.\n\nخبرٌ حسنٌ من مصدرٍ معتبَر: نقلًا عن الجزيرة نت، استهدفتْ إيرانُ دولتي الكويت والبحرين. وفي المقابلِ ردتْ أمريكا على مقتلِ جنودِها في الأردن.\n\nخبرٌ حسنٌ من مصدرٍ معتبَر: ونقلًا عن العربية، تجددتِ الهجماتُ الإيرانيةُ في المنطقة. واستهدفتْ هذهِ الهجماتُ محطةَ القوى الكهربائيةِ في الكويت.\n\nخبرٌ حسنٌ من مصدرٍ معتبَر: ونقلًا عن سكاي نيوز عربية، أعلنتِ الكويتُ عن تعرضِها لعدوانٍ جديد. حيثُ استهدفَ هجومٌ إيرانيٌّ محطةً ثانيةً لتوليدِ الكهرباء.\n\nخبرٌ حسنٌ من مصدرٍ معتبَر: ونقلًا عن الجزيرة نت، شهدتِ المنطقةُ هجماتٍ مكثفةً مؤخرًا. وأسفرَ القصفُ عن حريقٍ بكهرباءِ الكويت. كما استهدفتْ أمريكا بنى تحتيةً في إيران.\n\nونتحولُ في محورِنا الأخيرِ إلى الشؤونِ الخليجيةِ والملفاتِ الاقتصاديةِ والاستراتيجية.\n\nخبرٌ حسنٌ من مصدرٍ معتبَر: نقلًا عن سي إن إن بالعربية، كشفتْ مصادرُ ووثائقُ تفاصيلَ جديدة. وتتعلقُ هذهِ التفاصيلُ باتفاقٍ نوويٍّ بينَ السعوديةِ وأمريكا.\n\nخبرٌ حسنٌ من مصدرٍ معتبَر: ونقلًا عن العربية، تدعمُ الخططُ الاستراتيجيةُ البديلةُ اقتصادَ السعودية. وتسهمُ هذهِ الخططُ في تجاوزِ تحدياتٍ استثنائيةٍ عديدة.\n\nتحقَّقْ قبلَ أن تنشُر، فالكلمةُ أمانة.","audio":"bulletin-2026-07-19.mp3","video":"latest.mp4","items":[{"head":"إيران تستهدف الكويت والبحرين وأمريكا ترد على مقتل جنودها بالأردن","src":"الجزيرة نت","grade":"حسن"},{"head":"مصادر ووثائق تكشف آخر تفاصيل اتفاق نووي بين السعودية وأمريكا","src":"CNN Arabic","grade":"حسن"},{"head":"تجدد الهجمات الإيرانية ضد محطة القوى الكهربائية في الكويت","src":"العربية","grade":"حسن"},{"head":"الكويت: تعرُّض محطة ثانية لتوليد الكهرباء لهجوم إيراني","src":"سكاي نيوز عربية","grade":"حسن"},{"head":"هجمات مكثفة.. قصف وحريق بكهرباء الكويت واستهداف أمريكي لبنى تحتية بإيران","src":"الجزيرة نت","grade":"حسن"},{"head":"الخطط الاستراتيجية البديلة تدعم اقتصاد السعودية في تجاوز تحديات استثنائية","src":"العربية","grade":"حسن"},{"head":"مقتل فلسطينيين اثنين بنيران إسرائيلية شرقي غزة","src":"سكاي نيوز عربية","grade":"حسن"},{"head":"الجيش الإسرائيلي يقتل 11 فلسطينياً بينهم أطفال في غزة","src":"صحيفة الخليج","grade":"حسن"},{"head":"غزة.. مقتل 14 فلسطينيا نتيجة هجمات الجيش الإسرائيلي","src":"سكاي نيوز عربية","grade":"حسن"},{"head":"ثلاثة أطفال وامرأة من بين 15 قتيلاً في غزة من